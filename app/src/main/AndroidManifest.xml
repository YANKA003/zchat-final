<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:name=".ZChatApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme_GOODOK"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Main launcher activity (default theme icon) -->
        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="true"
            android:theme="@style/Theme_GOODOK" />

        <!-- Default theme icon alias -->
        <activity-alias
            android:name=".ui.auth.AuthActivityDefault"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:targetActivity=".ui.auth.AuthActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Classic theme icon alias -->
        <activity-alias
            android:name=".ui.auth.AuthActivityClassic"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_classic"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_classic"
            android:targetActivity=".ui.auth.AuthActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Modern theme icon alias -->
        <activity-alias
            android:name=".ui.auth.AuthActivityModern"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_modern"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_modern"
            android:targetActivity=".ui.auth.AuthActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Neon theme icon alias -->
        <activity-alias
            android:name=".ui.auth.AuthActivityNeon"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_neon"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_neon"
            android:targetActivity=".ui.auth.AuthActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Childish theme icon alias -->
        <activity-alias
            android:name=".ui.auth.AuthActivityChildish"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_childish"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_childish"
            android:targetActivity=".ui.auth.AuthActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.chats.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.calls.CallsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.channels.ChannelsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.contacts.ContactsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.premium.PremiumActivity"
            android:exported="false" />

        <activity
            android:name=".ui.calls.CallActivity"
            android:exported="false" />

        <!-- Firebase Messaging Service -->
        <service
            android:name=".services.GoodokMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
