<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Classic Theme -->
    <style name="Theme_GOODOK_Classic" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/classic_primary</item>
        <item name="colorPrimaryDark">@color/classic_secondary</item>
        <item name="colorAccent">@color/purple_200</item>
        <item name="android:windowBackground">@color/classic_background</item>
    </style>

    <!-- Modern Theme -->
    <style name="Theme_GOODOK_Modern" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/modern_primary</item>
        <item name="colorPrimaryDark">@color/modern_secondary</item>
        <item name="colorAccent">@color/teal_200</item>
        <item name="android:windowBackground">@color/modern_background</item>
    </style>

    <!-- Neon Theme -->
    <style name="Theme_GOODOK_Neon" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/neon_primary</item>
        <item name="colorPrimaryDark">@color/neon_secondary</item>
        <item name="colorAccent">@color/neon_primary</item>
        <item name="android:windowBackground">@color/neon_background</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/neon_primary</item>
    </style>

    <!-- Childish Theme -->
    <style name="Theme_GOODOK_Childish" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/childish_primary</item>
        <item name="colorPrimaryDark">@color/childish_secondary</item>
        <item name="colorAccent">@color/childish_primary</item>
        <item name="android:windowBackground">@color/childish_background</item>
    </style>

    <!-- Default Theme (Classic) -->
    <style name="Theme_GOODOK" parent="Theme_GOODOK_Classic" />
</resources>
