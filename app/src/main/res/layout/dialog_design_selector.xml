<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выберите дизайн"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выберите стиль оформления. Вы можете изменить его позже в настройках."
        android:textSize="14sp"
        android:textColor="#64748B"
        android:layout_marginBottom="16dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Design 1 Preview -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDesign1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Дизайн 1: Классический"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Индиго • Фиолетовый"
                                android:textSize="12sp"
                                android:textColor="#64748B"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/rbDesign1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivPreview1"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/preview_design1"
                        android:background="#F1F5F9"
                        android:contentDescription="Классический дизайн"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Design 2 Preview -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDesign2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Дизайн 2: Современный"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Синий • Розовый акцент"
                                android:textSize="12sp"
                                android:textColor="#64748B"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/rbDesign2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivPreview2"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/preview_design2"
                        android:background="#F1F5F9"
                        android:contentDescription="Современный дизайн"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Design 3 Preview (Neon) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDesign3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Дизайн 3: Neon"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Фиолетово-синий градиент"
                                android:textSize="12sp"
                                android:textColor="#64748B"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/rbDesign3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivPreview3"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/preview_design3"
                        android:background="#F1F5F9"
                        android:contentDescription="Neon дизайн"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Design 4 Preview (Drawn by a child) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDesign4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Drawn by a child"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1E293B"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Голубой • Фиолетовый • Желтый"
                                android:textSize="12sp"
                                android:textColor="#64748B"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/rbDesign4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivPreview4"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/preview_design4"
                        android:background="#F1F5F9"
                        android:contentDescription="Drawn by a child дизайн"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
