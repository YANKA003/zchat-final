<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <!-- Call UI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Caller Info -->
        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Вызов..."
            android:textSize="16sp"
            android:textColor="#aaaaaa"
            android:layout_marginBottom="48dp"/>

        <!-- Incoming Call Buttons -->
        <LinearLayout
            android:id="@+id/llIncomingCall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="48dp"
                android:background="@drawable/bg_call_decline"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@android:color/white"
                android:scaleType="center"
                android:contentDescription="Отклонить"/>

            <ImageButton
                android:id="@+id/btnAccept"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_call_accept"
                android:src="@android:drawable/ic_menu_call"
                android:tint="@android:color/white"
                android:scaleType="center"
                android:contentDescription="Принять"/>

        </LinearLayout>

        <!-- Active Call Buttons -->
        <LinearLayout
            android:id="@+id/llActiveCall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <!-- Call Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <ImageButton
                    android:id="@+id/btnMute"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_call_control"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:tint="@android:color/white"
                    android:scaleType="center"
                    android:contentDescription="Микрофон"/>

                <ImageButton
                    android:id="@+id/btnSpeaker"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_call_control"
                    android:src="@drawable/ic_speaker"
                    android:tint="@android:color/white"
                    android:scaleType="center"
                    android:contentDescription="Динамик"/>

                <ImageButton
                    android:id="@+id/btnVideo"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_call_control"
                    android:src="@android:drawable/ic_menu_camera"
                    android:tint="@android:color/white"
                    android:scaleType="center"
                    android:contentDescription="Видео"/>

            </LinearLayout>

            <!-- End Call Button -->
            <ImageButton
                android:id="@+id/btnEndCall"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_call_decline"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@android:color/white"
                android:scaleType="center"
                android:contentDescription="Завершить"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
